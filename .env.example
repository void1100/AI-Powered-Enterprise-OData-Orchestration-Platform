# Copy to .env for local development. Do not commit real secrets.

# App security
JWT_SECRET=replace-with-a-long-random-secret
ENVIRONMENT=development

# Graph/vector/auth storage
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
CHROMA_PERSIST_DIR=./backend/data/chroma_db
SQLITE_DB_PATH=./backend/data/app.db

# LLM provider. Use mock for offline demos.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini

# OpenAI-compatible providers such as Groq/OpenRouter
OPENAI_API_KEY=
OPENAI_API_KEYS=
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-r1
# To use MiniMax M3 through OpenRouter, set:
# LLM_PROVIDER=openrouter
# LLM_MODEL=minimax/minimax-m3

# Other providers
GEMINI_API_KEY=
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Optional sharing integrations through n8n
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=chatbot@yourcompany.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SLACK_WEBHOOK_URL=
